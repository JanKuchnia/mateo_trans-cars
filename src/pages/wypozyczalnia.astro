---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const fleet = [
  { name: "Bus dostawczy 3.5t (Winda)", type: "busy", details: "Pojemność 14 m³ · winda załadowcza · prawo jazdy kat. B", price: "od 180 zł / doba", image: "https://images.pexels.com/photos/15602197/pexels-photo-15602197.jpeg?auto=compress&cs=tinysrgb&w=800", rate: 180 },
  { name: "Bus dostawczy (Krótki)", type: "busy", details: "Pojemność 8 m³ · zwrotny i łatwy w parkowaniu · prawo jazdy kat. B", price: "od 140 zł / doba", image: "https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=800", rate: 140 },
  { name: "Laweta samochodowa 3.5t", type: "lawety", details: "Masa całkowita do 3500 kg · wyciągarka · najazdy aluminiowe", price: "od 220 zł / doba", image: "https://images.pexels.com/photos/6870729/pexels-photo-6870729.jpeg?auto=compress&cs=tinysrgb&w=800", rate: 220 },
  { name: "Bus 9-osobowy (Mikrobus)", type: "busy", details: "Komfortowa klimatyzacja · tempomat · idealny na wyjazdy grupowe", price: "od 200 zł / doba", image: "https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=800", rate: 200 },
  { name: "Przyczepa laweta dwuosiowa", type: "lawety", details: "Długość 4.5m · DMC do 2700kg · w zestawie pasy transportowe", price: "od 90 zł / doba", image: "https://images.pexels.com/photos/6870729/pexels-photo-6870729.jpeg?auto=compress&cs=tinysrgb&w=800", rate: 90 }
];

const faqs = [
  { q: "Jakie dokumenty są wymagane do wynajmu pojazdu?", a: "Do podpisania umowy najmu wymagamy: ważnego dowodu osobistego (lub paszportu) oraz prawa jazdy kategorii B (posiadanego od co najmniej 12 miesięcy). Transakcję możemy podpisać na osobę prywatną lub firmę." },
  { q: "Czy przy wynajmie pobierana jest kaucja?", a: "Tak, przy odbiorze pojazdu pobieramy kaucję zwrotną w wysokości od 500 do 1000 zł (w zależności od wybranego pojazdu). Kaucja zabezpiecza ewentualne szkody lub brak paliwa i jest rozliczana bezpośrednio przy zwrocie auta." },
  { q: "Czy wynajętym busem mogę wyjechać za granicę?", a: "Tak, dopuszczamy wyjazdy zagraniczne w strefie Schengen (kraje Unii Europejskiej). Wymaga to jednak wcześniejszego zgłoszenia podczas rezerwacji w celu przygotowania stosownego upoważnienia." },
  { q: "Czy obowiązuje limit kilometrów?", a: "Standardowo w cenie najmu dobowego uwzględniony jest limit 400 km na dobę. Przebieg ten jest sumowany dla całego okresu najmu. Istnieje możliwość indywidualnego zniesienia limitu za dodatkową opłatą." }
];
---

<Layout
  title="Wypożyczalnia busów i lawet Myślenice - MATEO TRANS & CARS"
  description="Wypożyczalnia busów dostawczych i lawet w Myślenicach. Wynajem na doby lub dłużej — przeprowadzki, transport auta, wyjazdy. Zadzwoń po cennik i dostępność."
>
  <!-- Custom Styles for Wypozyczalnia page -->
  <style>
    .filter-tab {
      background: #fff;
      border: 1px solid #e6e4e0;
      color: #5a5a60;
      padding: 10px 24px;
      border-radius: 4px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .filter-tab.active {
      background: #C8102E;
      color: #fff;
      border-color: #C8102E;
    }
    .filter-tab:hover:not(.active) {
      background: #f6f5f3;
      border-color: #c0beba;
      color: #141416;
    }
    .vehicle-card {
      transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
      will-change: transform, opacity;
    }
    .vehicle-card:hover {
      transform: translateY(-5px);
      border-color: #C8102E;
      box-shadow: 0 12px 32px rgba(20,20,22,0.08);
    }

    /* Calculator Styles */
    .calc-container {
      background: #fff;
      border: 1px solid #e6e4e0;
      border-radius: 6px;
      padding: 36px;
      box-shadow: 0 4px 20px rgba(20,20,22,0.02);
    }
    .calc-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 48px;
    }
    @media (max-width: 900px) {
      .calc-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }
    .input-group {
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .input-group label {
      font-size: 13.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #8a8a90;
    }
    .select-styled {
      padding: 14px;
      border-radius: 4px;
      border: 1px solid #e0dedb;
      font-family: inherit;
      font-size: 15px;
      outline: none;
      background: #f6f5f3;
      transition: border-color 0.2s ease;
    }
    .select-styled:focus {
      border-color: #C8102E;
    }
    .range-wrapper {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .range-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .range-val {
      font-family: ui-monospace, Menlo, monospace;
      font-weight: 700;
      color: #C8102E;
      background: #fdf2f4;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 14px;
    }
    .range-slider {
      -webkit-appearance: none;
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: #e6e4e0;
      outline: none;
    }
    .range-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #C8102E;
      cursor: pointer;
      transition: transform 0.1s ease;
    }
    .range-slider::-webkit-slider-thumb:hover {
      transform: scale(1.2);
    }
    .result-pane {
      background: #141416;
      color: #fff;
      border-radius: 6px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      position: relative;
      overflow: hidden;
      min-height: 280px;
    }
    .result-pane::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(200,16,46,0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Timeline Process Styles */
    .timeline-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 2px solid #141416;
      margin-top: 40px;
    }
    .timeline-item {
      padding: 28px 24px 30px 0;
      border-right: 1px solid #e6e4e0;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .timeline-item:last-child {
      border-right: none;
      padding-right: 0;
      padding-left: 24px;
    }
    .timeline-item:not(:first-child):not(:last-child) {
      padding-left: 24px;
    }
    @media (max-width: 900px) {
      .timeline-steps {
        grid-template-columns: 1fr;
        border-top: none;
        margin-top: 20px;
      }
      .timeline-item {
        padding: 24px 0 !important;
        border-right: none !important;
        border-bottom: 1px solid #e6e4e0;
      }
      .timeline-item:last-child {
        border-bottom: none;
      }
    }
  </style>

  <!-- ============ HERO ============ -->
  <section data-screen-label="Hero usługi" style="background:#141416;color:#fff;padding-top:88px">
    <div class="service-hero-grid"
      style="max-width:1200px;margin:0 auto;padding:88px 32px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center">
      <div style="display:flex;flex-direction:column;gap:22px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#9a9aa2;font-weight:700">02 — Wynajem</span>
        </div>
        <h1 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:48px;line-height:1.1;font-weight:800;margin:0;letter-spacing:-0.01em;text-wrap:balance">
          Wynajem busów i lawet</h1>
        <p style="font-size:17.5px;line-height:1.65;color:#b9b9c0;margin:0;max-width:520px;text-wrap:pretty">
          Flota busów dostawczych, osobowych oraz lawet gotowa do drogi na doby lub dłużej. Idealne rozwiązanie przy przeprowadzkach, transportowaniu pojazdów lub wyjazdach firmowych.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:8px">
          <a href="tel:+48536745745"
            style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:16px 30px;border-radius:4px;font-weight:700;font-size:15.5px">Zadzwoń i zarezerwuj: 536 745 745
          </a>
          <a href="#calc-section"
            style="display:inline-flex;align-items:center;gap:10px;border:1px solid #3a3a40;color:#fff;padding:16px 30px;border-radius:4px;font-weight:600;font-size:15.5px">Oblicz koszt najmu</a>
        </div>
      </div>
      <div style="min-height:360px;border-radius:6px;overflow:hidden;border:1px solid #2e2e34">
        <img src="https://images.pexels.com/photos/15602197/pexels-photo-15602197.jpeg?auto=compress&cs=tinysrgb&w=1200"
          alt="Bus dostawczy do wynajęcia" style="width:100%;height:100%;object-fit:cover;display:block">
      </div>
    </div>
  </section>

  <!-- ============ Dostępne pojazdy ============ -->
  <section style="padding:92px 32px;background:#f6f5f3">
    <div style="max-width:1200px;margin:0 auto">
      <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:44px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#8a8a90;font-weight:700">Flota pojazdów</span>
        </div>
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap">
          <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
            Nasza flota na wynajem
          </h2>
          <!-- Filter Tabs -->
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button class="filter-tab active" data-filter="all">Wszystkie</button>
            <button class="filter-tab" data-filter="busy">Busy (Dostawcze / Osobowe)</button>
            <button class="filter-tab" data-filter="lawety">Lawety & Przyczepy</button>
          </div>
        </div>
        <p style="margin:6px 0 0;font-size:14.5px;line-height:1.6;color:#5a5a60">
          Wszystkie pojazdy są w pełni sprawne, posiadają pełen pakiet ubezpieczeń (OC/AC/Assistance) i są przygotowane do tras krajowych oraz zagranicznych.
        </p>
      </div>

      <!-- Vehicle Grid -->
      <div class="cars-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px">
        {fleet.map((item) => (
          <div class="vehicle-card reveal-on-scroll" data-type={item.type}
            style="background:#fff;border:1px solid #e6e4e0;border-radius:6px;overflow:hidden;display:flex;flex-direction:column">
            <div style="height:190px;overflow:hidden">
              <img src={item.image} alt={item.name} style="width:100%;height:100%;object-fit:cover;display:block" />
            </div>
            <div style="padding:22px;display:flex;flex-direction:column;gap:6px;flex-grow:1">
              <span style="font-weight:800;font-size:17.5px;color:#141416">{item.name}</span>
              <span style="font-size:13.5px;color:#7a7a80">{item.details}</span>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:16px;border-top:1px solid #f2f0ec">
                <span style="font-weight:800;color:#C8102E;font-size:16.5px">{item.price}</span>
                <a href="tel:+48536745745" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#8a8a90">Rezerwuj →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ INTERAKTYWNY KALKULATOR KOSZTÓW ============ -->
  <section id="calc-section" style="padding:92px 32px">
    <div style="max-width:1200px;margin:0 auto">
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:44px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#8a8a90;font-weight:700">Kalkulator Wynajmu</span>
        </div>
        <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
          Oblicz orientacyjny koszt wynajmu
        </h2>
        <p style="font-size:15px;line-height:1.6;color:#5a5a60;margin:6px 0 0;max-width:640px">
          Im dłuższy okres najmu, tym niższa stawka dobiowa. Skorzystaj z kalkulatora, aby zobaczyć rabat i całkowity koszt najmu.
        </p>
      </div>

      <div class="calc-container">
        <div class="calc-grid">
          <!-- Inputs -->
          <div>
            <!-- Vehicle Selection -->
            <div class="input-group">
              <label for="vehicle-select">Wybierz pojazd</label>
              <select id="vehicle-select" class="select-styled">
                {fleet.map((item) => (
                  <option value={item.rate}>{item.name} — {item.price}</option>
                ))}
              </select>
            </div>

            <!-- Rental Days -->
            <div class="input-group">
              <div class="range-header">
                <label for="rental-days">Okres wynajmu (dni)</label>
                <span id="days-val" class="range-val">1 dzień</span>
              </div>
              <div class="range-wrapper">
                <input type="range" id="rental-days" min="1" max="30" value="1" class="range-slider" />
              </div>
            </div>

            <!-- Discount notice -->
            <div style="background:#f6f5f3;border-left:3px solid #C8102E;padding:16px;border-radius:0 4px 4px 0;font-size:13.5px;line-height:1.5;color:#5a5a60">
              <span style="font-weight:700;color:#141416">Progowe rabaty długoterminowe:</span>
              <ul style="margin:6px 0 0;padding-left:18px">
                <li>1 - 3 dni: stawka standardowa</li>
                <li>4 - 7 dni: <strong style="color:#C8102E">10% rabatu</strong> na każdą dobę</li>
                <li>8 dni i więcej: <strong style="color:#C8102E">15% rabatu</strong> na każdą dobę</li>
              </ul>
            </div>
          </div>

          <!-- Result Pane -->
          <div class="result-pane">
            <div style="display:flex;flex-direction:column;gap:12px;z-index:2;align-items:center">
              <span style="font-size:12px;letter-spacing:0.18em;text-transform:uppercase;color:#8a8a92;font-weight:700">Koszt Całkowity (Szacunkowy)</span>
              <div id="total-price" style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:38px;font-weight:800;color:#fff;margin:12px 0;letter-spacing:-0.02em">
                180 zł
              </div>
              <div id="rate-details" style="font-size:14px;color:#a0a0a8;margin-bottom:24px">
                Stawka dobowa: 180 zł (brak rabatu)
              </div>
              <a href="tel:+48536745745"
                style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:15px 28px;border-radius:4px;font-weight:700;font-size:15px;width:100%;justify-content:center;box-sizing:border-box">
                Zarezerwuj: 536 745 745
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROCES WYNAJMU (TIMELINE) ============ -->
  <section style="background:#fff;border-top:1px solid #e6e4e0;border-bottom:1px solid #e6e4e0">
    <div style="max-width:1200px;margin:0 auto;padding:92px 32px">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:44px">
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="width:34px;height:2px;background:#C8102E"></span>
            <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#8a8a90;font-weight:600">Rezerwacja</span>
          </div>
          <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
            Jak wygląda wynajem krok po kroku
          </h2>
        </div>
        <span style="font-size:14px;color:#7a7a80;max-width:320px">Od rezerwacji do odbioru kluczyków w kilka minut.</span>
      </div>

      <div class="timeline-steps">
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">01</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Rezerwacja telefoniczna</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Dzwonisz pod numer 536 745 745, wybierasz pojazd, potwierdzasz jego dostępność w Twoich terminach i rezerwujesz.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">02</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Podpisanie umowy najmu</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Przyjeżdżasz na nasz plac w Myślenicach. Spisujemy prostą, czytelną umowę najmu. Wystarczy prawo jazdy kat. B i dowód osobisty.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">03</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="10" x2="12" y2="10"></line>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Płatność & Kaucja</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Opłacasz z góry koszt wynajmu i zostawiasz zwrotną kaucję zabezpieczającą w gotówce. Odbierasz czysty, zatankowany pojazd.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">04</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 5-8 8h16l-8-8z"></path><path d="M12 13v8"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Zwrot i rozliczenie</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Oddajesz pojazd na placu o ustalonej godzinie (zatankowany). Odbierasz kaucję w pełnej kwocie. Gotowe!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ACCORDION ============ -->
  <section style="padding:92px 32px">
    <div style="max-width:900px;margin:0 auto">
      <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0 0 40px;letter-spacing:-0.01em;text-align:center">
        Najczęstsze pytania o wynajem
      </h2>
      <div style="border-top:1px solid #e6e4e0">
        {faqs.map((item, i) => (
          <div class="faq-item" style="border-bottom:1px solid #e6e4e0">
            <button class="faq-toggle"
              style="width:100%;background:none;border:none;padding:24px 4px;display:flex;align-items:center;justify-content:space-between;gap:20px;cursor:pointer;text-align:left;font-family:inherit">
              <span style="font-size:18px;font-weight:700;color:#141416">{item.q}</span>
              <svg class={`faq-icon${i === 0 ? ' faq-icon-active' : ''}`} width="22" height="22" viewBox="0 0 24 24" fill="none"
                stroke="#8a8a90" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                style="flex-shrink:0">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <line x1="12" y1="5" x2="12" y2="19" class="plus-vertical-line"></line>
              </svg>
            </button>
            <div class={`faq-answer-wrapper${i === 0 ? ' open' : ''}`}>
              <div class="faq-answer-content">
                <p style="margin:0;padding:0 4px 26px;font-size:15.5px;line-height:1.65;color:#5a5a60;max-width:680px;text-wrap:pretty">
                  {item.a}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SCRIPTS ============ -->
  <script>
    // 1. FLEET FILTERING
    const filterTabs = document.querySelectorAll('.filter-tab');
    const vehicleCards = document.querySelectorAll('.vehicle-card');

    filterTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const filterVal = tab.getAttribute('data-filter');

        vehicleCards.forEach((card) => {
          const type = card.getAttribute('data-type');
          if (filterVal === 'all' || type === filterVal) {
            (card as HTMLElement).style.display = 'flex';
            setTimeout(() => {
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transform = 'translateY(0)';
            }, 50);
          } else {
            (card as HTMLElement).style.opacity = '0';
            (card as HTMLElement).style.transform = 'translateY(8px)';
            setTimeout(() => {
              (card as HTMLElement).style.display = 'none';
            }, 300);
          }
        });
      });
    });

    // 2. RENTAL CALCULATOR LOGIC
    const vehicleSelect = document.getElementById('vehicle-select') as HTMLSelectElement;
    const daysSlider = document.getElementById('rental-days') as HTMLInputElement;
    const daysVal = document.getElementById('days-val') as HTMLElement;
    const totalPriceText = document.getElementById('total-price') as HTMLElement;
    const rateDetailsText = document.getElementById('rate-details') as HTMLElement;

    function calculateCost() {
      const baseRate = parseInt(vehicleSelect.value);
      const days = parseInt(daysSlider.value);

      // Determine discount
      let discount = 0;
      let discountLabel = 'brak rabatu';
      if (days >= 4 && days <= 7) {
        discount = 0.10;
        discountLabel = 'rabat 10%';
      } else if (days >= 8) {
        discount = 0.15;
        discountLabel = 'rabat 15%';
      }

      const discountedRate = Math.round(baseRate * (1 - discount));
      const totalCost = discountedRate * days;

      // Update values
      daysVal.textContent = days === 1 ? `1 dzień` : `${days} dni`;
      totalPriceText.textContent = `${totalCost.toLocaleString('pl-PL')} zł`;
      rateDetailsText.textContent = `Stawka dobowa po rabacie: ${discountedRate} zł (${discountLabel})`;
    }

    vehicleSelect.addEventListener('change', calculateCost);
    daysSlider.addEventListener('input', calculateCost);

    // Run once initially
    calculateCost();

    // 3. FAQ ACCORDION LOGIC
    document.querySelectorAll('.faq-item').forEach((item) => {
      const button = item.querySelector('.faq-toggle');
      const wrapper = item.querySelector('.faq-answer-wrapper');
      const icon = item.querySelector('.faq-icon');

      button?.addEventListener('click', () => {
        const isOpen = wrapper?.classList.contains('open');

        // Close all other accordions
        document.querySelectorAll('.faq-answer-wrapper.open').forEach((w) => w.classList.remove('open'));
        document.querySelectorAll('.faq-icon.faq-icon-active').forEach((i) => i.classList.remove('faq-icon-active'));

        if (!isOpen) {
          wrapper?.classList.add('open');
          icon?.classList.add('faq-icon-active');
        }
      });
    });
  </script>
</Layout>
