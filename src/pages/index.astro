---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const cars = [
  { name: "Ford Kuga", type: "SUV · osobowy", image: "https://images.pexels.com/photos/27138933/pexels-photo-27138933.jpeg?auto=compress&cs=tinysrgb&w=600" },
  { name: "Mitsubishi Outlander", type: "SUV · osobowy", image: "https://images.pexels.com/photos/2676096/pexels-photo-2676096.jpeg?auto=compress&cs=tinysrgb&w=600" },
  { name: "Seat Leon", type: "kompakt · osobowy", image: "https://images.pexels.com/photos/12982224/pexels-photo-12982224.jpeg?auto=compress&cs=tinysrgb&w=600" },
  { name: "Iveco Daily", type: "dostawczy", image: "https://images.pexels.com/photos/15602197/pexels-photo-15602197.jpeg?auto=compress&cs=tinysrgb&w=600" },
];

const reviews = [
  { text: "Profesjonalna i rzetelna pomoc przy leasingu i rejestracji — całkowicie bez presji sprzedażowej.", tag: "Zakup auta osobowego" },
  { text: "Wszystko wyjaśnione w szczegółach. Sprzedawca sam wspomniał o drobnej rysie, o której nie musiał mówić. Uczciwość na plus.", tag: "Zakup SUV-a" },
  { text: "Pełne wsparcie na każdym etapie, auto zgodne z ogłoszeniem, szybka dostawa. Polecam.", tag: "Zakup i dostawa" },
];

const faqs = [
  { q: "Czy pomagacie w leasingu i kredycie?", a: "Tak. Prowadzimy przez cały proces — od doboru finansowania, przez formalności, po rejestrację auta. Bez presji, spokojnie tłumaczymy każdy krok." },
  { q: "Nie widzę auta na placu — gdzie jest pełna oferta?", a: "Nasza aktualna oferta jest zawsze na Otomoto. Zapasy rotują, więc zdjęcia, ceny i opisy trzymamy w jednym, na bieżąco aktualizowanym miejscu." },
  { q: "Jak wygląda wypożyczenie busa lub lawety?", a: "Zadzwoń i powiedz na kiedy oraz na jak długo potrzebujesz pojazdu — sprawdzimy dostępność i podamy cenę. Wynajmujemy na doby lub dłużej." },
  { q: "Odkupujecie auta?", a: "Tak, prowadzimy skup samochodów osobowych i dostawczych. Wycenimy Twoje auto i przedstawimy konkretną ofertę — bez zobowiązań." },
  { q: "Na jakim obszarze działa pomoc drogowa?", a: "Myślenice i okolice. Holujemy i transportujemy auta osobowe oraz dostawcze — jeden telefon i ruszamy." },
];
---

<Layout
  title="MATEO TRANS & CARS - Komis, Transport, Pomoc Drogowa"
  description="MATEO TRANS & CARS - Komis samochodowy Myślenice. Skup i sprzedaż aut osobowych oraz dostawczych, wypożyczalnia busów i lawet, pomoc drogowa."
>
  <!-- ============ HERO ============ -->
  <section id="top" data-screen-label="Hero" style="background:#141416;color:#fff;padding-top:88px">
    <div class="hero-grid"
      style="max-width:1200px;margin:0 auto;padding:88px 32px 0;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center">
      <div style="display:flex;flex-direction:column;gap:26px;padding-bottom:88px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span
            style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#9a9aa2;font-weight:600">Od
            2019 na Otomoto</span>
        </div>
        <h1
          style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:52px;line-height:1.08;font-weight:800;margin:0;letter-spacing:-0.01em;text-wrap:balance">
          Samochody, transport i&nbsp;pomoc drogowa w&nbsp;Myślenicach.</h1>
        <p style="font-size:17.5px;line-height:1.65;color:#b9b9c0;margin:0;max-width:520px;text-wrap:pretty">Komis
          samochodowy prowadzony uczciwie i bez presji — do tego wypożyczalnia busów i lawet, sprzedaż nowych skuterów
          wodnych oraz pomoc drogowa na miejscu i w trasie.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap">
          <a href="https://mateocars.otomoto.pl/inventory" target="_blank" rel="noopener"
            style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:16px 30px;border-radius:4px;font-weight:700;font-size:15.5px;letter-spacing:0.02em">Zobacz auta na Otomoto<svg width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              style="flex-shrink:0">
              <path d="M15 3h6v6"></path>
              <path d="M10 14 21 3"></path>
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            </svg></a>
          <a href="#uslugi"
            style="display:inline-flex;align-items:center;gap:10px;border:1px solid #3a3a40;color:#fff;padding:16px 30px;border-radius:4px;font-weight:600;font-size:15.5px">Poznaj usługi<svg width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              style="flex-shrink:0">
              <path d="M12 5v14"></path>
              <path d="m19 12-7 7-7-7"></path>
            </svg></a>
        </div>
        <div style="display:flex;align-items:center;gap:12px;margin-top:6px">
          <span style="color:#e8b923;font-size:15px;letter-spacing:2px">★★★★★</span>
          <span style="font-size:14px;color:#9a9aa2">Wysoko oceniani przez klientów w Google</span>
        </div>
      </div>
      <div style="align-self:stretch;display:flex">
        <div style="flex:1;min-height:440px;border:1px solid #2e2e34;border-bottom:none;overflow:hidden">
          <img src="https://images.pexels.com/photos/116675/pexels-photo-116675.jpeg?auto=compress&cs=tinysrgb&w=1200"
            alt="Samochody na placu komisu" style="width:100%;height:100%;object-fit:cover;display:block">
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PASEK POMOCY DROGOWEJ ============ -->
  <div data-screen-label="Pasek pomocy drogowej" style="background:#C8102E;color:#fff">
    <div class="assist-bar-content"
      style="max-width:1200px;margin:0 auto;padding:14px 32px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;font-size:15px">
      <span style="font-weight:800;letter-spacing:0.08em;text-transform:uppercase;font-size:13px">Pomoc drogowa</span>
      <span style="opacity:0.55">·</span>
      <span>Zadzwoń, przyjedziemy:</span>
      <a href="tel:+48791072708"
        style="display:inline-flex;align-items:center;gap:8px;font-weight:800;font-size:17px;border-bottom:2px solid rgba(255,255,255,0.4)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
          </path>
        </svg>791 072 708</a>
      <span style="opacity:0.55">lub</span>
      <a href="tel:+48536745745"
        style="display:inline-flex;align-items:center;gap:8px;font-weight:800;font-size:17px;border-bottom:2px solid rgba(255,255,255,0.4)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
          </path>
        </svg>536 745 745</a>
    </div>
  </div>

  <!-- ============ PASEK PARTNERÓW ============ -->
  <section data-screen-label="Partnerzy" style="background:#fff;border-bottom:1px solid #e6e4e0">
    <div class="partners-content"
      style="max-width:1200px;margin:0 auto;padding:28px 32px;display:flex;align-items:center;gap:40px;flex-wrap:wrap">
      <span
        style="font-size:12px;letter-spacing:0.2em;text-transform:uppercase;color:#8a8a90;font-weight:700;white-space:nowrap">Współpracujemy
        z</span>
      <div class="partners-logos" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;flex:1">
        <a href="https://mateocars.otomoto.pl/inventory" target="_blank" rel="noopener"
          style="height:44px;padding:0 22px;display:flex;align-items:center;justify-content:center;border:1px solid #e6e4e0;border-radius:5px;font-weight:800;letter-spacing:0.02em;color:#141416;font-size:15px">otomoto</a>
        <div
          style="height:44px;padding:0 22px;display:flex;align-items:center;justify-content:center;border:1px dashed #d8d6d2;border-radius:5px;font-family:ui-monospace,Menlo,monospace;font-size:11px;color:#a0a0a6">
          logo partnera leasingowego</div>
        <div
          style="height:44px;padding:0 22px;display:flex;align-items:center;justify-content:center;border:1px dashed #d8d6d2;border-radius:5px;font-family:ui-monospace,Menlo,monospace;font-size:11px;color:#a0a0a6">
          logo ubezpieczyciela</div>
        <div
          style="height:44px;padding:0 22px;display:flex;align-items:center;justify-content:center;border:1px dashed #d8d6d2;border-radius:5px;font-family:ui-monospace,Menlo,monospace;font-size:11px;color:#a0a0a6">
          logo banku / SkP</div>
      </div>
    </div>
  </section>

  <!-- ============ USŁUGI ============ -->
  <section id="uslugi" data-screen-label="Usługi" style="padding:92px 32px 40px">
    <div style="max-width:1200px;margin:0 auto">
      <div
        style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:44px">
        <h2 class="reveal-on-scroll"
          style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
          Czym się zajmujemy</h2>
        <span style="font-size:14px;color:#7a7a80">Cztery usługi, jedno miejsce — ul. Tarnówka 3e, Myślenice</span>
      </div>
      <div class="services-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

        <a class="reveal-on-scroll" href={`${base}komis/`}
          style="background:#fff;border:1px solid #e6e4e0;border-radius:6px;padding:34px;display:flex;flex-direction:column;gap:14px">
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#C8102E;font-weight:700">01
            — Sprzedaż</span>
          <h3 style="font-size:23px;font-weight:700;margin:0">Komis samochodowy</h3>
          <p style="font-size:15px;line-height:1.6;color:#5a5a60;margin:0;text-wrap:pretty">Sprawdzone auta osobowe i
            dostawcze. Skup, sprzedaż, pomoc w leasingu i rejestracji. Pełna, aktualna oferta zawsze na Otomoto.</p>
          <span
            style="margin-top:auto;display:flex;align-items:center;gap:8px;font-weight:700;font-size:14.5px;color:#C8102E">Zobacz
            więcej<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg></span>
        </a>

        <a class="reveal-on-scroll" href={`${base}wypozyczalnia/`}
          style="background:#fff;border:1px solid #e6e4e0;border-radius:6px;padding:34px;display:flex;flex-direction:column;gap:14px">
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#C8102E;font-weight:700">02
            — Wynajem</span>
          <h3 style="font-size:23px;font-weight:700;margin:0">Wypożyczalnia busów i lawet</h3>
          <p style="font-size:15px;line-height:1.6;color:#5a5a60;margin:0;text-wrap:pretty">Busy dostawcze i lawety na
            doby lub dłużej — na przeprowadzkę, transport auta czy wyjazd. Zapytaj o dostępność i cennik.</p>
          <span
            style="margin-top:auto;display:flex;align-items:center;gap:8px;font-weight:700;font-size:14.5px;color:#C8102E">Zobacz
            więcej<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg></span>
        </a>

        <a class="reveal-on-scroll" href={`${base}skutery-wodne/`}
          style="background:#fff;border:1px solid #e6e4e0;border-radius:6px;padding:34px;display:flex;flex-direction:column;gap:14px">
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#C8102E;font-weight:700">03
            — Nowość</span>
          <h3 style="font-size:23px;font-weight:700;margin:0">Nowe skutery wodne</h3>
          <p style="font-size:15px;line-height:1.6;color:#5a5a60;margin:0;text-wrap:pretty">Sprzedaż nowych skuterów
            wodnych. Skontaktuj się, aby poznać dostępne modele i terminy dostaw.</p>
          <span
            style="margin-top:auto;display:flex;align-items:center;gap:8px;font-weight:700;font-size:14.5px;color:#C8102E">Zobacz
            więcej<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg></span>
        </a>

        <a class="reveal-on-scroll" href={`${base}pomoc-drogowa/`}
          style="background:#141416;border:1px solid #141416;border-radius:6px;padding:34px;display:flex;flex-direction:column;gap:14px;color:#fff">
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#C8102E;font-weight:700">04
            — W trasie</span>
          <h3 style="font-size:23px;font-weight:700;margin:0">Pomoc drogowa</h3>
          <p style="font-size:15px;line-height:1.6;color:#b9b9c0;margin:0;text-wrap:pretty">Holowanie i transport aut
            osobowych oraz dostawczych. Jeden telefon i ruszamy — Myślenice i okolice.</p>
          <span
            style="margin-top:auto;display:flex;align-items:center;gap:8px;font-weight:700;font-size:14.5px;color:#C8102E">Zobacz
            więcej<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ OFERTA AUT ============ -->
  <section data-screen-label="Oferta aut" style="padding:52px 32px 92px">
    <div style="max-width:1200px;margin:0 auto">
      <div
        style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:36px">
        <h2 class="reveal-on-scroll"
          style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
          Z naszego placu</h2>
        <a href="https://mateocars.otomoto.pl/inventory" target="_blank" rel="noopener"
          style="display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:15px;color:#C8102E">Pełna
          oferta na Otomoto<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
            <path d="M15 3h6v6"></path>
            <path d="M10 14 21 3"></path>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          </svg></a>
      </div>
      <div class="cars-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px">
        {cars.map((car) => (
          <a href="https://mateocars.otomoto.pl/inventory" target="_blank" rel="noopener" class="reveal-on-scroll"
            style="background:#fff;border:1px solid #e6e4e0;border-radius:6px;overflow:hidden;display:flex;flex-direction:column">
            <div style="height:150px;overflow:hidden">
              <img src={car.image} alt={car.name} style="width:100%;height:100%;object-fit:cover;display:block" />
            </div>
            <div style="padding:18px 20px 20px;display:flex;flex-direction:column;gap:6px">
              <span style="font-weight:700;font-size:16.5px">{car.name}</span>
              <span style="font-size:13.5px;color:#7a7a80">{car.type}</span>
              <span
                style="display:flex;align-items:center;gap:7px;font-size:13.5px;font-weight:700;color:#C8102E;margin-top:6px">Cena
                i szczegóły na Otomoto<svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  style="flex-shrink:0">
                  <path d="M5 12h14"></path>
                  <path d="m12 5 7 7-7 7"></path>
                </svg></span>
            </div>
          </a>
        ))}
      </div>
      <p style="margin:22px 0 0;font-size:13.5px;color:#8a8a90">Oferta rotuje — aktualne ceny, zdjęcia i opisy zawsze
        w naszym profilu Otomoto.</p>
    </div>
  </section>

  <!-- ============ PROCES ZAKUPU ============ -->
  <section id="proces" data-screen-label="Proces zakupu"
    style="background:#fff;border-top:1px solid #e6e4e0;border-bottom:1px solid #e6e4e0">
    <div style="max-width:1200px;margin:0 auto;padding:88px 32px">
      <div
        style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:48px">
        <h2 class="reveal-on-scroll"
          style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
          Jak kupujesz u nas auto</h2>
        <span style="font-size:14px;color:#7a7a80;max-width:340px">Cztery proste kroki — prowadzimy Cię za rękę na
          każdym etapie.</span>
      </div>
      <div class="process-grid"
        style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:2px solid #141416">
        <div class="process-step reveal-on-scroll"
          style="padding:28px 26px 30px 0;border-right:1px solid #e6e4e0;display:flex;flex-direction:column;gap:14px">
          <div style="display:flex;align-items:center;gap:12px">
            <span
              style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">01</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Wybór auta</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">Przeglądasz ofertę na Otomoto lub dzwonisz
            — podpowiemy, co pasuje do Twoich potrzeb i budżetu.</p>
        </div>
        <div class="process-step reveal-on-scroll"
          style="padding:28px 26px 30px 26px;border-right:1px solid #e6e4e0;display:flex;flex-direction:column;gap:14px">
          <div style="display:flex;align-items:center;gap:12px">
            <span
              style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">02</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2">
              </path>
              <circle cx="7" cy="17" r="2"></circle>
              <path d="M9 17h6"></path>
              <circle cx="17" cy="17" r="2"></circle>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Jazda i oględziny</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">Sprawdzasz auto na spokojnie. Pokazujemy
            stan bez upiększania — łącznie z drobnymi wadami.</p>
        </div>
        <div class="process-step reveal-on-scroll"
          style="padding:28px 26px 30px 26px;border-right:1px solid #e6e4e0;display:flex;flex-direction:column;gap:14px">
          <div style="display:flex;align-items:center;gap:12px">
            <span
