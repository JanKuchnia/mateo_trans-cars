  {
    id: "bmw-f30",
    name: "BMW Serii 3 F30",
    category: "osobowe",
    fuel: "benzyna",
    gearbox: "automatyczna",
    year: 2016,
    mileage: 165000,
    price: 68000,
    priceFormatted: "68 000 zł",
    engine: "2.0 TwinPower Turbo",
    power: "184 KM",
    body: "Sedan",
    vin: "WBA8A11020KXXXXXX",
    warranty: "12 miesięcy (gratis)",
    details: "Wersja Sport Line, reflektory LED, sportowa automatyczna skrzynia biegów z łopatkami, czarna skórzana tapicerka, napęd sDrive.",
    image: "https://images.pexels.com/photos/33419739/pexels-photo-33419739.jpeg?auto=compress&cs=tinysrgb&w=800"
  }
];
---

<Layout
  title="Oferta aut i wirtualny komis - Mateo Trans&Cars"
  description="Przeglądaj aktualnie dostępne auta osobowe i dostawcze na naszym placu w Myślenicach. Filtruj modele, sprawdzaj ratę leasingu i rezerwuj oględziny."
>
  <style>
    .komis-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 120px 24px 60px;
    }
    .main-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 32px;
    }
    #toggle-filters-btn {
      display: none;
    }
    @media (max-width: 900px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
      .filter-panel-wrapper {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s var(--spring-smooth);
        overflow: hidden;
      }
      .filter-panel-wrapper.open {
        grid-template-rows: 1fr;
        margin-bottom: 24px;
      }
      .filter-panel {
        position: static !important;
        min-height: 0;
      }
      #toggle-filters-btn {
        display: flex !important;
      }
    }
    .filter-panel {
      background: #fff;
      border: 1px solid #e6e4e0;
      border-radius: 4px;
      padding: 24px;
      position: sticky;
      top: 110px;
    }
    .search-input {
      width: 100%;
      padding: 11px 14px;
      border: 1px solid #e0dedb;
      border-radius: 4px;
      font-family: inherit;
      font-size: 14px;
      background: #f6f5f3;
      box-sizing: border-box;
      outline: none;
      transition: all 0.2s ease;
      margin-bottom: 20px;
    }
    .search-input:focus {
      border-color: #C8102E;
      background: #fff;
    }
    .filter-group {
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid #f2f0ec;
    }
    .filter-label {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8a8a90;
      display: block;
      margin-bottom: 10px;
    }
    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      color: #3a3a40;
      cursor: pointer;
      margin-bottom: 8px;
    }
    .checkbox-item input {
      accent-color: #C8102E;
      cursor: pointer;
    }
    .car-card {
      background: #fff;
      border: 1px solid #e6e4e0;
      border-radius: 4px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .car-card:hover {
      border-color: #C8102E;
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(20, 20, 22, 0.05);
    }
    .car-spec-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      font-size: 13px;
      color: #7a7a80;
      border-top: 1px solid #f2f0ec;
      padding-top: 12px;
      margin-top: auto;
    }

    /* Modal styles */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(20, 20, 22, 0.6);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    @media (max-width: 900px) {
      .modal-overlay {
        padding: 12px;
      }
    }
    .modal-content {
      background: #fff;
      border-radius: 4px;
      max-width: 960px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      overflow-x: hidden;
      position: relative;
      border: 1px solid #e6e4e0;
      box-shadow: 0 24px 64px rgba(0,0,0,0.15);
    }
    .modal-body-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 36px;
      padding: 36px;
    }
    @media (max-width: 900px) {
      .modal-overlay {
        padding: 0;
        align-items: flex-end;
      }
      .modal-content {
        max-width: 100vw;
        width: 100%;
        border-radius: 12px 12px 0 0;
        max-height: 92vh;
        box-shadow: 0 -8px 32px rgba(0,0,0,0.18);
      }
      .modal-body-grid {
        grid-template-columns: 1fr;
        gap: 16px;
        padding: 16px;
      }
      #modal-img { height: 180px !important; }
      #modal-title { font-size: 18px !important; }
      #modal-price { font-size: 22px !important; }
      .spec-table td { font-size: 12.5px; padding: 7px 0; }
      .calc-box { padding: 14px; }
      .slider-header { font-size: 12px; }
      #calc-monthly-rate { font-size: 18px !important; }
    }
    .close-modal {
      position: absolute;
      top: 16px;
      right: 16px;
      background: #f6f5f3;
      border: 1px solid #e6e4e0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 16px;
      z-index: 10;
      transition: all 0.2s ease;
    }
    .close-modal:hover {
      background: #C8102E;
      color: #fff;
      border-color: #C8102E;
    }
    .spec-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .spec-table td {
      padding: 10px 0;
      border-bottom: 1px solid #f2f0ec;
    }
    .spec-table td:first-child {
      font-weight: 700;
      color: #8a8a90;
      width: 40%;
    }
    .spec-table td:last-child {
      color: #141416;
      font-weight: 600;
    }

    /* Calculator */
    .calc-box {
      background: #f6f5f3;
      border: 1px solid #e6e4e0;
      border-radius: 4px;
      padding: 22px;
      margin-top: 20px;
    }
    .slider-group {
      margin-bottom: 16px;
    }
    .slider-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
      font-size: 13px;
      font-weight: 700;
      color: #5a5a60;
    }
    .range-slider {
      -webkit-appearance: none;
      width: 100%;
      height: 4px;
      border-radius: 2px;
      background: #e0dedb;
      outline: none;
    }
    .range-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #C8102E;
      cursor: pointer;
      transition: transform 0.1s ease;
    }
    .range-slider::-webkit-slider-thumb:hover {
      transform: scale(1.25);
    }
  </style>

  <div class="komis-container">
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:36px">
      <div style="display:flex;align-items:center;gap:12px">
        <span style="width:34px;height:2px;background:#C8102E"></span>
        <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#8a8a90;font-weight:600">Wirtualny komis</span>
      </div>
      <h1 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:36px;font-weight:800;margin:0;letter-spacing:-0.01em">
        Oferta aut na placu
      </h1>
      <p style="font-size:15px;color:#5a5a60;margin:0;max-width:680px">
        Skorzystaj z wirtualnego salonu, aby przeszukać naszą flotę sprawdzonych pojazdów gotowych do odbioru w Myślenicach. Sprawdź pełną specyfikację techniczną i oblicz ratę leasingową.
      </p>
    </div>

    <button id="toggle-filters-btn" style="display:none;background:#141416;color:#fff;border:none;padding:12px 20px;border-radius:4px;font-weight:700;font-size:14px;cursor:pointer;align-items:center;justify-content:center;gap:10px;width:100%;margin-bottom:20px;box-sizing:border-box">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
      <span>Filtry i sortowanie</span>
    </button>

    <div class="main-grid">
      <!-- Filter Sidebar -->
      <div class="filter-panel-wrapper" id="filter-wrapper">
        <div class="filter-panel">
          <input type="text" id="search-box" class="search-input" placeholder="Szukaj auta..." />

        <!-- Category -->
        <div class="filter-group">
          <span class="filter-label">Kategoria</span>
          <label class="checkbox-item"><input type="checkbox" class="cat-filter" value="osobowe" checked /> Osobowe</label>
          <label class="checkbox-item"><input type="checkbox" class="cat-filter" value="dostawcze" checked /> Dostawcze</label>
        </div>

        <!-- Fuel -->
        <div class="filter-group">
          <span class="filter-label">Paliwo</span>
          <label class="checkbox-item"><input type="checkbox" class="fuel-filter" value="diesel" checked /> Diesel</label>
          <label class="checkbox-item"><input type="checkbox" class="fuel-filter" value="benzyna" checked /> Benzyna</label>
        </div>

        <!-- Gearbox -->
        <div class="filter-group">
          <span class="filter-label">Skrzynia biegów</span>
          <label class="checkbox-item"><input type="checkbox" class="gearbox-filter" value="manualna" checked /> Manualna</label>
          <label class="checkbox-item"><input type="checkbox" class="gearbox-filter" value="automatyczna" checked /> Automatyczna</label>
        </div>

        <!-- Sorting -->
        <div>
          <span class="filter-label">Sortowanie</span>
          <select id="sort-select" style="width:100%;padding:10px;border-radius:4px;border:1px solid #e0dedb;background:#f6f5f3;font-family:inherit;font-size:13.5px;outline:none">
            <option value="price-asc">Cena: rosnąco</option>
            <option value="price-desc">Cena: malejąco</option>
            <option value="year-desc">Rocznik: najnowsze</option>
            <option value="mileage-asc">Przebieg: najniższy</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Showroom Gallery -->
      <div>
        <div id="cars-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px">
          {cars.map((car) => (
            <div class="car-card" data-id={car.id} data-name={car.name} data-category={car.category} data-fuel={car.fuel} data-gearbox={car.gearbox} data-price={car.price} data-year={car.year} data-mileage={car.mileage}>
              <div style="height:180px;overflow:hidden;position:relative">
                <img src={car.image} alt={car.name} style="width:100%;height:100%;object-fit:cover;display:block" />
                <span style="position:absolute;top:12px;left:12px;background:#C8102E;color:#fff;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;padding:5px 9px;border-radius:2px">Sprawdzone</span>
              </div>
              <div style="padding:20px;display:flex;flex-direction:column;flex-grow:1">
                <h3 style="font-size:17.5px;font-weight:700;margin:0 0-4px;color:#141416">{car.name}</h3>
                <span style="font-size:13px;color:#8a8a90;font-weight:600">{car.engine} · {car.power}</span>
                
                <div class="car-spec-grid">
                  <div>Rok: <strong>{car.year}</strong></div>
                  <div>Przebieg: <strong>{car.mileage.toLocaleString("pl-PL")} km</strong></div>
                  <div style="text-transform:capitalize">Skrzynia: <strong>{car.gearbox}</strong></div>
                  <div style="text-transform:capitalize">Paliwo: <strong>{car.fuel}</strong></div>
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;border-top:1px solid #f2f0ec;margin-top:16px;padding-top:16px">
                  <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:18px;font-weight:800;color:#C8102E">{car.priceFormatted}</span>
                  <span style="font-size:12.5px;font-weight:700;color:#8a8a90">Szczegóły →</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div id="no-cars" style="display:none;text-align:center;padding:80px 24px;border:1px dashed #e6e4e0;border-radius:4px;color:#8a8a90;font-size:15px">
          Brak aut pasujących do wybranych filtrów. Spróbuj zmienić parametry wyszukiwania.
        </div>
      </div>
    </div>
  </div>

  <!-- ============ DETAIL MODAL ============ -->
  <div id="car-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="close-modal" id="close-modal-btn">✕</button>
      
      <div class="modal-body-grid" id="modal-body-grid">
        <!-- Left: Image & Specs -->
        <div>
          <div style="height:260px;overflow:hidden;border-radius:4px;border:1px solid #e6e4e0;margin-bottom:24px">
            <img id="modal-img" src="" alt="Auto" style="width:100%;height:100%;object-fit:cover;display:block" />
          </div>

          <h2 id="modal-title" style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:26px;font-weight:800;margin:0 0 6px;color:#141416">Volkswagen Passat B8</h2>
          <p id="modal-desc" style="font-size:14.5px;line-height:1.6;color:#5a5a60;margin:0 0 24px">Opis...</p>

          <table class="spec-table">
            <tbody>
              <tr>
                <td>Model i silnik</td>
                <td id="modal-spec-engine">--</td>
              </tr>
              <tr>
                <td>Moc silnika</td>
                <td id="modal-spec-power">--</td>
              </tr>
              <tr>
                <td>Typ nadwozia</td>
                <td id="modal-spec-body">--</td>
              </tr>
              <tr>
                <td>Rocznik</td>
                <td id="modal-spec-year">--</td>
              </tr>
              <tr>
                <td>Przebieg</td>
                <td id="modal-spec-mileage">--</td>
              </tr>
              <tr>
                <td>Skrzynia biegów</td>
                <td id="modal-spec-gearbox" style="text-transform:capitalize">--</td>
              </tr>
              <tr>
                <td>Rodzaj paliwa</td>
                <td id="modal-spec-fuel" style="text-transform:capitalize">--</td>
              </tr>
              <tr>
                <td>Numer VIN</td>
                <td id="modal-spec-vin" style="font-family:monospace;letter-spacing:0.03em">--</td>
              </tr>
              <tr>
                <td>Gwarancja komisowa</td>
                <td id="modal-spec-warranty">--</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Right: Financing Calculator & Inquiry Form -->
        <div>
          <div style="background:#141416;color:#fff;border-radius:4px;padding:24px;margin-bottom:24px;text-align:center">
            <span style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:#8a8a92;font-weight:700">Cena brutto</span>
            <div id="modal-price" style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:32px;font-weight:800;color:#fff;margin:6px 0;letter-spacing:-0.01em">-- zł</div>
            <span style="font-size:12.5px;color:#a0a0a8">Faktura VAT Marża / Kupujący zwolniony z PCC 2%</span>
          </div>

          <!-- Financing Calculator -->
          <div class="calc-box">
            <h4 style="font-size:14px;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;color:#141416;margin:0 0 16px">
              Kalkulator finansowania (Leasing/Kredyt)
            </h4>
            
            <div class="slider-group">
              <div class="slider-header">
                <span>Wpłata własna</span>
                <span id="calc-own-pct">20%</span>
              </div>
              <input type="range" id="slider-own" min="0" max="50" step="5" value="20" class="range-slider" />
              <div style="display:flex;justify-content:space-between;font-size:11px;color:#8a8a90;margin-top:6px">
                <span>0 zł (0%)</span>
                <span id="calc-own-val">-- zł</span>
              </div>
            </div>

            <div class="slider-group" style="margin-bottom:20px">
              <div class="slider-header">
                <span>Okres spłaty</span>
                <span id="calc-months-val">48 miesięcy</span>
              </div>
              <input type="range" id="slider-months" min="24" max="84" step="12" value="48" class="range-slider" />
              <div style="display:flex;justify-content:space-between;font-size:11px;color:#8a8a90;margin-top:6px">
                <span>2 lata (24 msc)</span>
                <span>7 lat (84 msc)</span>
              </div>
            </div>

            <div style="display:flex;justify-content:space-between;align-items:baseline;padding-top:14px;border-top:1px solid #e0dedb">
              <span style="font-weight:700;font-size:13.5px;color:#5a5a60">Szacowana rata:</span>
              <div style="text-align:right">
                <span id="calc-monthly-rate" style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:22px;font-weight:800;color:#C8102E">-- zł</span>
                <span style="display:block;font-size:10.5px;color:#8a8a90">miesięcznie netto</span>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <form id="inquiry-form" style="margin-top:24px;display:flex;flex-direction:column;gap:12px">
            <h4 style="font-size:14px;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;color:#141416;margin:0">
              Zapytaj o to auto
            </h4>
            <input type="text" id="inquiry-name" placeholder="Imię i nazwisko" class="input-field" style="background:#f6f5f3;padding:11px;border:1px solid #e0dedb;font-family:inherit;font-size:13.5px;border-radius:4px" required />
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <input type="tel" id="inquiry-phone" placeholder="Telefon" class="input-field" style="background:#f6f5f3;padding:11px;border:1px solid #e0dedb;font-family:inherit;font-size:13.5px;border-radius:4px" required />
              <input type="email" id="inquiry-email" placeholder="E-mail" class="input-field" style="background:#f6f5f3;padding:11px;border:1px solid #e0dedb;font-family:inherit;font-size:13.5px;border-radius:4px" required />
            </div>
            <textarea id="inquiry-msg" placeholder="Dzień dobry, piszę w sprawie ogłoszenia..." class="input-field" style="background:#f6f5f3;padding:11px;border:1px solid #e0dedb;font-family:inherit;font-size:13.5px;border-radius:4px;min-height:70px;resize:vertical" required></textarea>
            <button type="submit" class="phone-btn" style="background:#C8102E;color:#fff;border:none;padding:12px;border-radius:4px;font-weight:700;font-size:14px;cursor:pointer;text-align:center">
              Wyślij zapytanie ofertowe
            </button>
          </form>
          
          <div id="inquiry-success" style="display:none;background:#e6f4ea;border:1px solid #c2e7c9;color:#137333;padding:16px;border-radius:4px;margin-top:20px;text-align:center;font-weight:700;font-size:14px">
            Dziękujemy! Wiadomość została wysłana do konsultanta.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ JAVASCRIPT ============ -->
  <script>
    interface Car {
      id: string;
      name: string;
      category: string;
      fuel: string;
      gearbox: string;
      year: number;
      mileage: number;
      price: number;
      priceFormatted: string;
      engine: string;
      power: string;
      body: string;
      vin: string;
      warranty: string;
      details: string;
      image: string;
    }

    const carDataList: Car[] = [
      {
        id: "passat-b8",
        name: "Volkswagen Passat B8",
        category: "osobowe",
        fuel: "diesel",
        gearbox: "automatyczna",
        year: 2018,
        mileage: 178000,
        price: 54900,
        priceFormatted: "54 900 zł",
        engine: "2.0 TDI",
        power: "150 KM",
        body: "Kombi",
        vin: "WVWZZZ3CZJE0XXXXX",
        warranty: "12 miesięcy (gratis)",
        details: "Salon Polska, 1 właściciel, pełna historia serwisowa ASO, stan bezwypadkowy, bogate wyposażenie Comfortline.",
        image: "https://images.pexels.com/photos/18029637/pexels-photo-18029637.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      {
        id: "transit-custom",
        name: "Ford Transit Custom",
        category: "dostawcze",
        fuel: "diesel",
        gearbox: "manualna",
        year: 2019,
        mileage: 142000,
        price: 62500,
        priceFormatted: "62 500 zł",
        engine: "2.0 TDCi EcoBlue",
        power: "130 KM",
        body: "Furgon L2H1",
        vin: "WF0YXXTTGYKEXXXXX",
        warranty: "6 miesięcy",
        details: "Klimatyzacja, czujniki parkowania przód/tył, tempomat, przestrzeń ładunkowa wyłożona sklejką wodoodporną.",
        image: "https://images.pexels.com/photos/29380589/pexels-photo-29380589.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      {
        id: "octavia-3",
        name: "Skoda Octavia III",
        category: "osobowe",
        fuel: "diesel",
        gearbox: "manualna",
        year: 2017,
        mileage: 195000,
        price: 41900,
        priceFormatted: "41 900 zł",
        engine: "1.6 TDI",
        power: "115 KM",
        body: "Kombi",
        vin: "TMBJJ7NE8H0XXXXXX",
        warranty: "6 miesięcy",
        details: "Bardzo ekonomiczny silnik, nawigacja satelitarna, czujniki parkowania, dwustrefowa klimatyzacja automatyczna, regularnie serwisowany.",
        image: "https://images.pexels.com/photos/16531727/pexels-photo-16531727.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      {
        id: "master-l3h2",
        name: "Renault Master L3H2",
        category: "dostawcze",
        fuel: "diesel",
        gearbox: "manualna",
        year: 2020,
        mileage: 190000,
        price: 74900,
        priceFormatted: "74 900 zł",
        engine: "2.3 dCi Energy",
        power: "145 KM",
        body: "Furgon L3H2",
        vin: "VF1VB000668XXXXXX",
        warranty: "12 miesięcy (opcja)",
        details: "Klimatyzacja, nawigacja, kamera cofania, pneumatyczny fotel kierowcy, oświetlenie LED paki ładunkowej.",
        image: "https://images.pexels.com/photos/6169662/pexels-photo-6169662.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      {
        id: "bmw-f30",
        name: "BMW Serii 3 F30",
        category: "osobowe",
        fuel: "benzyna",
        gearbox: "automatyczna",
        year: 2016,
        mileage: 165000,
        price: 68000,
        priceFormatted: "68 000 zł",
        engine: "2.0 TwinPower Turbo",
        power: "184 KM",
        body: "Sedan",
        vin: "WBA8A11020KXXXXXX",
        warranty: "12 miesięcy (gratis)",
        details: "Wersja Sport Line, reflektory LED, sportowa automatyczna skrzynia biegów z łopatkami, czarna skórzana tapicerka, napęd sDrive.",
        image: "https://images.pexels.com/photos/33419739/pexels-photo-33419739.jpeg?auto=compress&cs=tinysrgb&w=800"
      }
    ];

    let activeCar: Car | null = null;

    // DOM selectors
    const searchBox = document.getElementById('search-box') as HTMLInputElement;
    const catFilters = document.querySelectorAll('.cat-filter');
    const fuelFilters = document.querySelectorAll('.fuel-filter');
    const gearboxFilters = document.querySelectorAll('.gearbox-filter');
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const carsGrid = document.getElementById('cars-grid');
    const noCarsText = document.getElementById('no-cars');

    // Filter and Sort Logic
    function filterAndSortCars() {
      const query = searchBox.value.toLowerCase().trim();
      const activeCats = Array.from(catFilters).filter(i => (i as HTMLInputElement).checked).map(i => (i as HTMLInputElement).value);
      const activeFuels = Array.from(fuelFilters).filter(i => (i as HTMLInputElement).checked).map(i => (i as HTMLInputElement).value);
      const activeGearboxes = Array.from(gearboxFilters).filter(i => (i as HTMLInputElement).checked).map(i => (i as HTMLInputElement).value);
      
      const cards = Array.from(document.querySelectorAll('.car-card'));
      let visibleCount = 0;

      // Filter
      cards.forEach((card) => {
        const name = (card.getAttribute('data-name') || '').toLowerCase();
        const cat = card.getAttribute('data-category') || '';
        const fuel = card.getAttribute('data-fuel') || '';
        const gearbox = card.getAttribute('data-gearbox') || '';

        const matchesQuery = name.includes(query);
        const matchesCat = activeCats.includes(cat);
        const matchesFuel = activeFuels.includes(fuel);
        const matchesGearbox = activeGearboxes.includes(gearbox);

        if (matchesQuery && matchesCat && matchesFuel && matchesGearbox) {
          (card as HTMLElement).style.display = 'flex';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      if (noCarsText) noCarsText.style.display = visibleCount === 0 ? 'block' : 'none';

      // Sort visible cards in DOM
      const sortedCards = cards
        .filter(card => (card as HTMLElement).style.display !== 'none')
        .sort((a, b) => {
          const sortVal = sortSelect.value;
          if (sortVal === 'price-asc') {
            return parseInt(a.getAttribute('data-price') || '0') - parseInt(b.getAttribute('data-price') || '0');
          } else if (sortVal === 'price-desc') {
            return parseInt(b.getAttribute('data-price') || '0') - parseInt(a.getAttribute('data-price') || '0');
          } else if (sortVal === 'year-desc') {
            return parseInt(b.getAttribute('data-year') || '0') - parseInt(a.getAttribute('data-year') || '0');
          } else if (sortVal === 'mileage-asc') {
            return parseInt(a.getAttribute('data-mileage') || '0') - parseInt(b.getAttribute('data-mileage') || '0');
          }
          return 0;
        });

      if (carsGrid) {
        sortedCards.forEach(card => carsGrid.appendChild(card));
      }
    }

    searchBox?.addEventListener('input', filterAndSortCars);
    catFilters.forEach(el => el.addEventListener('change', filterAndSortCars));
    fuelFilters.forEach(el => el.addEventListener('change', filterAndSortCars));
    gearboxFilters.forEach(el => el.addEventListener('change', filterAndSortCars));
    sortSelect?.addEventListener('change', filterAndSortCars);

    // Initial Filter Run
    filterAndSortCars();

    // Modal DOM Selectors
    const modal = document.getElementById('car-modal') as HTMLElement;
    const closeModalBtn = document.getElementById('close-modal-btn');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title') as HTMLElement;
    const modalDesc = document.getElementById('modal-desc') as HTMLElement;
    const modalPrice = document.getElementById('modal-price') as HTMLElement;

    const modalSpecEngine = document.getElementById('modal-spec-engine') as HTMLElement;
    const modalSpecPower = document.getElementById('modal-spec-power') as HTMLElement;
    const modalSpecBody = document.getElementById('modal-spec-body') as HTMLElement;
    const modalSpecYear = document.getElementById('modal-spec-year') as HTMLElement;
    const modalSpecMileage = document.getElementById('modal-spec-mileage') as HTMLElement;
    const modalSpecGearbox = document.getElementById('modal-spec-gearbox') as HTMLElement;
    const modalSpecFuel = document.getElementById('modal-spec-fuel') as HTMLElement;
    const modalSpecVin = document.getElementById('modal-spec-vin') as HTMLElement;
    const modalSpecWarranty = document.getElementById('modal-spec-warranty') as HTMLElement;

    // Calculator DOM
    const sliderOwn = document.getElementById('slider-own') as HTMLInputElement;
    const sliderMonths = document.getElementById('slider-months') as HTMLInputElement;
    const calcOwnPct = document.getElementById('calc-own-pct') as HTMLElement;
    const calcOwnVal = document.getElementById('calc-own-val') as HTMLElement;
    const calcMonthsVal = document.getElementById('calc-months-val') as HTMLElement;
    const calcMonthlyRate = document.getElementById('calc-monthly-rate') as HTMLElement;

    // Inquiry Form DOM
    const inquiryForm = document.getElementById('inquiry-form') as HTMLFormElement;
    const inquirySuccess = document.getElementById('inquiry-success');

    function calculateFinancing() {
      if (!activeCar) return;

      const price = activeCar.price;
      const ownPct = parseInt(sliderOwn.value);
      const months = parseInt(sliderMonths.value);

      const ownValue = Math.round(price * (ownPct / 100));
      const financedAmount = price - ownValue;

      // Realistic interest rate calculation (7.5% annual rate + 2.5% margin = ~10% APR)
      // Formula for monthly annuity: P * r * (1+r)^n / ((1+r)^n - 1)
      const annualRate = 0.098;
      const r = annualRate / 12;
      const n = months;

      let monthlyPayment = 0;
      if (financedAmount > 0) {
        monthlyPayment = Math.round(financedAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1));
      }

      // Update UI
      calcOwnPct.textContent = `${ownPct}%`;
      calcOwnVal.textContent = `${ownValue.toLocaleString('pl-PL')} zł`;
      calcMonthsVal.textContent = `${months} miesięcy (${Math.round(months/12)} lat)`;
      calcMonthlyRate.textContent = `${monthlyPayment.toLocaleString('pl-PL')} zł`;
    }

    sliderOwn?.addEventListener('input', calculateFinancing);
    sliderMonths?.addEventListener('input', calculateFinancing);

    // Open Modal
    document.querySelectorAll('.car-card').forEach((card) => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-id');
        const found = carDataList.find(c => c.id === id);
        if (found) {
          activeCar = found;
          
          // Populate data
          modalImg.src = found.image;
          modalImg.alt = found.name;
          modalTitle.textContent = found.name;
          modalDesc.textContent = found.details;
          modalPrice.textContent = found.priceFormatted;

          modalSpecEngine.textContent = found.engine;
          modalSpecPower.textContent = found.power;
          modalSpecBody.textContent = found.body;
          modalSpecYear.textContent = found.year.toString();
          modalSpecMileage.textContent = `${found.mileage.toLocaleString('pl-PL')} km`;
          modalSpecGearbox.textContent = found.gearbox;
          modalSpecFuel.textContent = found.fuel;
          modalSpecVin.textContent = found.vin;
          modalSpecWarranty.textContent = found.warranty;

          // Set placeholders in inquiry text
          const msgArea = document.getElementById('modal-desc');
          const msgInput = document.getElementById('inquiry-msg') as HTMLTextAreaElement;
          if (msgInput) {
            msgInput.value = `Dzień dobry, piszę w sprawie ogłoszenia: ${found.name}. Proszę o informację o dostępności auta i ewentualną ofertę finansowania.`;
          }

          // Reset success alert
          if (inquirySuccess) inquirySuccess.style.display = 'none';
          if (inquiryForm) inquiryForm.style.display = 'flex';

          // Reset calculator values
          sliderOwn.value = "20";
          sliderMonths.value = "48";
          calculateFinancing();

          // Display modal
          if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden'; // Lock background scroll
          }
        }
      });
    });

    // Close Modal
    function closeModal() {
      if (modal) {
        modal.style.display = 'none';
        document.body.style.overflow = ''; // Unlock background scroll
        activeCar = null;
      }
    }

    closeModalBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Handle form submit inside modal
    inquiryForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Simulate sending inquiry
      if (inquiryForm) inquiryForm.style.display = 'none';
      if (inquirySuccess) inquirySuccess.style.display = 'block';
    });

    // Toggle Filters for Mobile
    const toggleFiltersBtn = document.getElementById('toggle-filters-btn');
    const filterWrapper = document.getElementById('filter-wrapper');
    if (toggleFiltersBtn && filterWrapper) {
      toggleFiltersBtn.addEventListener('click', () => {
        filterWrapper.classList.toggle('open');
        const isOpen = filterWrapper.classList.contains('open');
        toggleFiltersBtn.style.background = isOpen ? '#C8102E' : '#141416';
      });
    }
  </script>
</Layout>
