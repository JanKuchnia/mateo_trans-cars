---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const models = [
  {
    id: "yamaha",
    name: "Yamaha VX Cruiser",
    power: "125 KM",
    capacity: "3-osobowy",
    engine: "TR-1 High Output, 3-cylindrowy, 1049 cm³",
    features: "Wyświetlacz RiDE · duży schowek · tryb Eco",
    price: "od 59 900 zł",
    basePrice: 59900,
    image: "https://images.pexels.com/photos/33102733/pexels-photo-33102733.jpeg?auto=compress&cs=tinysrgb&w=800"
  },
  {
    id: "seadoo",
    name: "Sea-Doo GTI SE",
    power: "130 KM",
    capacity: "3-osobowy",
    engine: "Rotax 1630 ACE, 3-cylindrowy",
    features: "System iBR (hamulec i wsteczny) · głośniki Bluetooth · stopień wejściowy",
    price: "od 64 500 zł",
    basePrice: 64500,
    image: "https://images.pexels.com/photos/10364376/pexels-photo-10364376.jpeg?auto=compress&cs=tinysrgb&w=800"
  },
  {
    id: "kawasaki",
    name: "Kawasaki Ultra 160",
    power: "160 KM",
    capacity: "3-osobowy",
    engine: "4-cylindrowy, 1498 cm³",
    features: "Kadłub o sportowej charakterystyce · kamera wsteczna · regulowana kierownica",
    price: "od 71 200 zł",
    basePrice: 71200,
    image: "https://images.pexels.com/photos/30200707/pexels-photo-30200707.jpeg?auto=compress&cs=tinysrgb&w=800"
  }
];

const faqs = [
  { q: "Czy pomagacie w rejestracji skuterów wodnych?", a: "Tak, dostarczamy komplet dokumentów wymaganych do rejestracji skutera wodnego w polskim systemie REJA24. Doradzamy jak sprawnie zgłosić pojazd i uzyskać numer rejestracyjny." },
  { q: "Jak wygląda kwestia gwarancji i serwisu?", a: "Każdy sprzedawany przez nas skuter jest fabrycznie nowy i posiada pełną, oficjalną gwarancję producenta honorowaną w autoryzowanych serwisach w całej Polsce (zazwyczaj 2 lata)." },
  { q: "Czy w zestawie ze skuterem jest przyczepka?", a: "Skutery sprzedawane są osobno. W ofercie posiadamy jednak dedykowane przyczepy transportowe (płozowe) renomowanych marek w atrakcyjnych pakietach ze skuterem." },
  { q: "Jakie uprawnienia są potrzebne do pływania skuterem?", a: "W Polsce do legalnego prowadzenia skutera wodnego wymagany jest patent sternika motorowodnego. Pomagamy i doradzamy, gdzie można szybko i sprawnie odbyć odpowiednie szkolenie." }
];
---

<Layout
  title="Nowe skutery wodne Myślenice - MATEO TRANS & CARS"
  description="Sprzedaż nowych skuterów wodnych w Myślenicach. Skontaktuj się, aby poznać dostępne modele i terminy dostaw."
>
  <!-- Custom Styles for Skutery Wodne page -->
  <style>
    .config-tab {
      background: #fff;
      border: 1px solid #e6e4e0;
      color: #5a5a60;
      padding: 14px 28px;
      border-radius: 4px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      flex: 1;
      text-align: center;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .config-tab.active {
      background: #C8102E;
      color: #fff;
      border-color: #C8102E;
    }
    .config-tab:hover:not(.active) {
      background: #f6f5f3;
      border-color: #c0beba;
      color: #141416;
    }

    /* Interactive Spec Layout */
    .spec-container {
      background: #fff;
      border: 1px solid #e6e4e0;
      border-radius: 6px;
      padding: 36px;
      box-shadow: 0 4px 20px rgba(20,20,22,0.02);
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 48px;
    }
    @media (max-width: 900px) {
      .spec-container {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }

    .spec-table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0 24px;
    }
    .spec-table td {
      padding: 12px 0;
      border-bottom: 1px solid #f2f0ec;
      font-size: 14.5px;
    }
    .spec-table td:first-child {
      font-weight: 700;
      color: #8a8a90;
      width: 35%;
    }
    .spec-table td:last-child {
      color: #141416;
      font-weight: 600;
    }

    .addon-card {
      border: 1px solid #e0dedb;
      border-radius: 4px;
      padding: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      cursor: pointer;
      background: #f6f5f3;
      transition: all 0.2s ease;
      user-select: none;
    }
    .addon-card.selected {
      border-color: #C8102E;
      background: #fff5f6;
    }
    .addon-checkbox {
      width: 18px;
      height: 18px;
      border: 2px solid #a0a0a6;
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }
    .addon-card.selected .addon-checkbox {
      background: #C8102E;
      border-color: #C8102E;
    }
    .addon-checkbox::after {
      content: '✓';
      color: #fff;
      font-size: 11px;
      font-weight: bold;
      display: none;
    }
    .addon-card.selected .addon-checkbox::after {
      display: block;
    }

    .price-pane {
      background: #141416;
      color: #fff;
      border-radius: 6px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      position: relative;
      overflow: hidden;
      min-height: 280px;
    }
    .price-pane::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(200,16,46,0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Timeline Process Styles */
    .timeline-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 2px solid #141416;
      margin-top: 40px;
    }
    .timeline-item {
      padding: 28px 24px 30px 0;
      border-right: 1px solid #e6e4e0;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .timeline-item:last-child {
      border-right: none;
      padding-right: 0;
      padding-left: 24px;
    }
    .timeline-item:not(:first-child):not(:last-child) {
      padding-left: 24px;
    }
    @media (max-width: 900px) {
      .timeline-steps {
        grid-template-columns: 1fr;
        border-top: none;
        margin-top: 20px;
      }
      .timeline-item {
        padding: 24px 0 !important;
        border-right: none !important;
        border-bottom: 1px solid #e6e4e0;
      }
      .timeline-item:last-child {
        border-bottom: none;
      }
    }
  </style>

  <!-- ============ HERO ============ -->
  <section data-screen-label="Hero usługi" style="background:#141416;color:#fff;padding-top:88px">
    <div class="service-hero-grid"
      style="max-width:1200px;margin:0 auto;padding:88px 32px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center">
      <div style="display:flex;flex-direction:column;gap:22px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#C8102E;font-weight:700">03 — Nowość w ofercie</span>
        </div>
        <h1 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:48px;line-height:1.1;font-weight:800;margin:0;letter-spacing:-0.01em;text-wrap:balance">
          Nowe skutery wodne na zamówienie</h1>
        <p style="font-size:17.5px;line-height:1.65;color:#b9b9c0;margin:0;max-width:520px;text-wrap:pretty">
          Rozszerzyliśmy naszą działalność o autoryzowaną sprzedaż skuterów wodnych wiodących producentów. Doradzimy w wyborze modelu, skompletujemy przyczepę oraz akcesoria i załatwimy formalności rejestracyjne.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:8px">
          <a href="tel:+48536745745"
            style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:16px 30px;border-radius:4px;font-weight:700;font-size:15.5px">Zapytaj o dostępność: 536 745 745</a>
          <a href="#config-section"
            style="display:inline-flex;align-items:center;gap:10px;border:1px solid #3a3a40;color:#fff;padding:16px 30px;border-radius:4px;font-weight:600;font-size:15.5px">Konfiguruj i wyceń</a>
        </div>
      </div>
      <div style="min-height:360px;border-radius:6px;overflow:hidden;border:1px solid #2e2e34">
        <img src="https://images.pexels.com/photos/33058476/pexels-photo-33058476.jpeg?auto=compress&cs=tinysrgb&w=1200"
          alt="Skuter wodny" style="width:100%;height:100%;object-fit:cover;display:block">
      </div>
    </div>
  </section>

  <!-- ============ INTERAKTYWNA KONFIGURACJA ============ -->
  <section id="config-section" style="padding:92px 32px;background:#f6f5f3">
    <div style="max-width:1200px;margin:0 auto">
      <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:44px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="width:34px;height:2px;background:#C8102E"></span>
          <span style="font-size:12px;letter-spacing:0.22em;text-transform:uppercase;color:#8a8a90;font-weight:700">Wybór Modelu</span>
        </div>
        <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
          Porównaj specyfikację i skonfiguruj skuter
        </h2>
        <p style="margin:6px 0 0;font-size:14.5px;line-height:1.6;color:#5a5a60;max-width:640px">
          Wybierz model skutera z tabeli poniżej, dobierz akcesoria opcjonalne i sprawdź szacunkową cenę zestawu gotowego do zwodowania.
        </p>

        <!-- Model tabs -->
        <div style="display:flex;gap:12px;margin-top:24px;width:100%;max-width:700px;flex-wrap:wrap">
          {models.map((item, idx) => (
            <button class={`config-tab${idx === 0 ? ' active' : ''}`} data-model={item.id} data-price={item.basePrice}>
              {item.name}
            </button>
          ))}
        </div>
      </div>

      <!-- Configurator Panel -->
      <div class="spec-container">
        <!-- Spec details & options -->
        <div>
          <h3 id="selected-model-title" style="font-size:24px;font-weight:800;margin:0;color:#141416">Yamaha VX Cruiser</h3>
          
          <!-- Spec table -->
          <table class="spec-table">
            <tbody>
              <tr>
                <td>Moc silnika</td>
                <td id="spec-power">125 KM</td>
              </tr>
              <tr>
                <td>Liczba miejsc</td>
                <td id="spec-capacity">3-osobowy</td>
              </tr>
              <tr>
                <td>Typ silnika</td>
                <td id="spec-engine">TR-1 High Output, 3-cylindrowy, 1049 cm³</td>
              </tr>
              <tr>
                <td>Wyposażenie</td>
                <td id="spec-features">Wyświetlacz RiDE · duży schowek · tryb Eco</td>
              </tr>
            </tbody>
          </table>

          <!-- Accessories selection -->
          <h4 style="font-size:14px;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;color:#8a8a90;margin:0 0 16px">
            Wyposażenie dodatkowe
          </h4>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div class="addon-card" data-price="1500">
              <div style="display:flex;flex-direction:column;gap:4px">
                <span style="font-weight:700;font-size:15px">Pokrowiec ochronny premium</span>
                <span style="font-size:13px;color:#7a7a80">Wodoodporny, idealnie dopasowany do kadłuba</span>
              </div>
              <div style="display:flex;align-items:center;gap:16px">
                <span style="font-weight:700;color:#C8102E">+1 500 zł</span>
                <div class="addon-checkbox"></div>
              </div>
            </div>

            <div class="addon-card" data-price="4500">
              <div style="display:flex;flex-direction:column;gap:4px">
                <span style="font-weight:700;font-size:15px">Dedykowana przyczepa transportowa</span>
                <span style="font-size:13px;color:#7a7a80">Wersja płozowa z wyciągarką i pasami mocującymi</span>
              </div>
              <div style="display:flex;align-items:center;gap:16px">
                <span style="font-weight:700;color:#C8102E">+4 500 zł</span>
                <div class="addon-checkbox"></div>
              </div>
            </div>

            <div class="addon-card" data-price="3000">
              <div style="display:flex;flex-direction:column;gap:4px">
                <span style="font-weight:700;font-size:15px">Fabryczny system audio Bluetooth</span>
                <span style="font-size:13px;color:#7a7a80">Głośniki wodoodporne montowane w konsoli</span>
              </div>
              <div style="display:flex;align-items:center;gap:16px">
                <span style="font-weight:700;color:#C8102E">+3 000 zł</span>
                <div class="addon-checkbox"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Preview & Final Price -->
        <div class="price-pane">
          <div style="height:160px;overflow:hidden;border-radius:4px;width:100%;margin-bottom:24px;border:1px solid #2e2e34">
            <img id="model-image" src="https://images.pexels.com/photos/33102733/pexels-photo-33102733.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Podgląd modelu" style="width:100%;height:100%;object-fit:cover;display:block" />
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;z-index:2;align-items:center;width:100%">
            <span style="font-size:12px;letter-spacing:0.18em;text-transform:uppercase;color:#8a8a92;font-weight:700">Wycena Konfiguracji</span>
            <div id="final-price" style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:38px;font-weight:800;color:#fff;margin:8px 0;letter-spacing:-0.02em">
              59 900 zł
            </div>
            <div id="base-price-label" style="font-size:13.5px;color:#a0a0a8;margin-bottom:20px">
              Cena bazowa: 59 900 zł
            </div>
            <a href="tel:+48536745745"
              style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:15px 28px;border-radius:4px;font-weight:700;font-size:15px;width:100%;justify-content:center;box-sizing:border-box">
              Zapytaj o ten zestaw: 536 745 745
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROCES ZAKUPU (TIMELINE) ============ -->
  <section style="background:#fff;border-top:1px solid #e6e4e0;border-bottom:1px solid #e6e4e0">
    <div style="max-width:1200px;margin:0 auto;padding:92px 32px">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:44px">
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="width:34px;height:2px;background:#C8102E"></span>
            <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#8a8a90;font-weight:600">Jak kupić</span>
          </div>
          <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0;letter-spacing:-0.01em">
            Proces zamówienia skutera wodnego
          </h2>
        </div>
        <span style="font-size:14px;color:#7a7a80;max-width:320px">Od doradztwa po wydanie zestawu z dokumentacją.</span>
      </div>

      <div class="timeline-steps">
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">01</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Konsultacja & Wybór</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Dzwonisz pod numer 536 745 745 lub odwiedzasz nasz plac. Wybieramy skuter pasujący do Twoich umiejętności i potrzeb.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">02</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Dodatki & Doposażenie</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Konfigurujemy zestaw. Dobieramy fabryczny pokrowiec, przyczepkę, kapoki oraz środki asekuracyjne.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">03</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Formalności & Rezerwacja</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Wpłacasz zadatek rezerwacyjny, a my sprowadzamy skuter od producenta lub przygotowujemy model z bieżących dostaw.
          </p>
        </div>
        <div class="timeline-item reveal-on-scroll">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-family:'Archivo Expanded','Archivo',sans-serif;font-weight:800;font-size:15px;color:#C8102E">04</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141416" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="m2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path>
            </svg>
          </div>
          <h3 style="font-size:18px;font-weight:700;margin:0">Odbiór gotowego zestawu</h3>
          <p style="font-size:14px;line-height:1.6;color:#5a5a60;margin:0">
            Odbierasz skuter na placu w Myślenicach wraz z kompletem dokumentów rejestracyjnych w systemie REJA24. Skuter gotowy na wodę!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ACCORDION ============ -->
  <section style="padding:92px 32px">
    <div style="max-width:900px;margin:0 auto">
      <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:34px;font-weight:800;margin:0 0 40px;letter-spacing:-0.01em;text-align:center">
        Najczęstsze pytania o skutery wodne
      </h2>
      <div style="border-top:1px solid #e6e4e0">
        {faqs.map((item, i) => (
          <div class="faq-item" style="border-bottom:1px solid #e6e4e0">
            <button class="faq-toggle"
              style="width:100%;background:none;border:none;padding:24px 4px;display:flex;align-items:center;justify-content:space-between;gap:20px;cursor:pointer;text-align:left;font-family:inherit">
              <span style="font-size:18px;font-weight:700;color:#141416">{item.q}</span>
              <svg class={`faq-icon${i === 0 ? ' faq-icon-active' : ''}`} width="22" height="22" viewBox="0 0 24 24" fill="none"
                stroke="#8a8a90" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                style="flex-shrink:0">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <line x1="12" y1="5" x2="12" y2="19" class="plus-vertical-line"></line>
              </svg>
            </button>
            <div class={`faq-answer-wrapper${i === 0 ? ' open' : ''}`}>
              <div class="faq-answer-content">
                <p style="margin:0;padding:0 4px 26px;font-size:15.5px;line-height:1.65;color:#5a5a60;max-width:680px;text-wrap:pretty">
                  {item.a}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SCRIPTS ============ -->
  <script>
    // 1. DATA AND STATE FOR CONFIGURATOR
    const modelData: Record<string, { name: string; power: string; capacity: string; engine: string; features: string; price: number; image: string }> = {
      yamaha: {
        name: "Yamaha VX Cruiser",
        power: "125 KM",
        capacity: "3-osobowy",
        engine: "TR-1 High Output, 3-cylindrowy, 1049 cm³",
        features: "Wyświetlacz RiDE · duży schowek · tryb Eco",
        price: 59900,
        image: "https://images.pexels.com/photos/33102733/pexels-photo-33102733.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      seadoo: {
        name: "Sea-Doo GTI SE",
        power: "130 KM",
        capacity: "3-osobowy",
        engine: "Rotax 1630 ACE, 3-cylindrowy",
        features: "System iBR (hamulec i wsteczny) · głośniki Bluetooth · stopień wejściowy",
        price: 64500,
        image: "https://images.pexels.com/photos/10364376/pexels-photo-10364376.jpeg?auto=compress&cs=tinysrgb&w=800"
      },
      kawasaki: {
        name: "Kawasaki Ultra 160",
        power: "160 KM",
        capacity: "3-osobowy",
        engine: "4-cylindrowy, 1498 cm³",
        features: "Kadłub o sportowej charakterystyce · kamera wsteczna · regulowana kierownica",
        price: 71200,
        image: "https://images.pexels.com/photos/30200707/pexels-photo-30200707.jpeg?auto=compress&cs=tinysrgb&w=800"
      }
    };

    let activeModelId = 'yamaha';
    const activeAddons = new Set<number>();

    // DOM Elements
    const modelTabs = document.querySelectorAll('.config-tab');
    const modelTitle = document.getElementById('selected-model-title') as HTMLElement;
    const specPower = document.getElementById('spec-power') as HTMLElement;
    const specCapacity = document.getElementById('spec-capacity') as HTMLElement;
    const specEngine = document.getElementById('spec-engine') as HTMLElement;
    const specFeatures = document.getElementById('spec-features') as HTMLElement;
    const modelImage = document.getElementById('model-image') as HTMLImageElement;
    const finalPriceText = document.getElementById('final-price') as HTMLElement;
    const basePriceLabel = document.getElementById('base-price-label') as HTMLElement;
    const addonCards = document.querySelectorAll('.addon-card');

    function updateConfigurator() {
      const data = modelData[activeModelId];
      if (!data) return;

      // Update Spec info
      modelTitle.textContent = data.name;
      specPower.textContent = data.power;
      specCapacity.textContent = data.capacity;
      specEngine.textContent = data.engine;
      specFeatures.textContent = data.features;
      modelImage.src = data.image;
      modelImage.alt = data.name;

      // Calculate total price
      let total = data.price;
      activeAddons.forEach(addonPrice => {
        total += addonPrice;
      });

      // Update Price panel
      const formatter = new Intl.NumberFormat('pl-PL');
      finalPriceText.textContent = `${formatter.format(total)} zł`;
      basePriceLabel.textContent = `Cena bazowa: ${formatter.format(data.price)} zł`;
    }

    // Model Selection Tabs
    modelTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        modelTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        activeModelId = tab.getAttribute('data-model') || 'yamaha';
        updateConfigurator();
      });
    });

    // Addons Selection
    addonCards.forEach((card) => {
      card.addEventListener('click', () => {
        card.classList.toggle('selected');
        const price = parseInt(card.getAttribute('data-price') || '0');

        if (card.classList.contains('selected')) {
          activeAddons.add(price);
        } else {
          activeAddons.delete(price);
        }

        updateConfigurator();
      });
    });

    // Initial setup
    updateConfigurator();

    // 2. FAQ ACCORDION LOGIC
    document.querySelectorAll('.faq-item').forEach((item) => {
      const button = item.querySelector('.faq-toggle');
      const wrapper = item.querySelector('.faq-answer-wrapper');
      const icon = item.querySelector('.faq-icon');

      button?.addEventListener('click', () => {
        const isOpen = wrapper?.classList.contains('open');

        // Close all other accordions
        document.querySelectorAll('.faq-answer-wrapper.open').forEach((w) => w.classList.remove('open'));
        document.querySelectorAll('.faq-icon.faq-icon-active').forEach((i) => i.classList.remove('faq-icon-active'));

        if (!isOpen) {
          wrapper?.classList.add('open');
          icon?.classList.add('faq-icon-active');
        }
      });
    });
  </script>
</Layout>
