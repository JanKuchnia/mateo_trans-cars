---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Pomoc drogowa Myślenice - MATEO TRANS & CARS"
  description="Pomoc drogowa Myślenice i okolice. Holowanie i transport aut osobowych oraz dostawczych. Jeden telefon i ruszamy."
>
  <section data-screen-label="Hero usługi" style="background:#141416;color:#fff;padding-top:88px">
    <div class="service-hero-grid"
      style="max-width:1200px;margin:0 auto;padding:88px 32px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center">
      <div style="display:flex;flex-direction:column;gap:22px">
        <span style="font-size:12.5px;letter-spacing:0.24em;text-transform:uppercase;color:#C8102E;font-weight:700">04 — W trasie</span>
        <h1 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:44px;line-height:1.12;font-weight:800;margin:0;letter-spacing:-0.01em;text-wrap:balance">
          Pomoc drogowa</h1>
        <p style="font-size:17px;line-height:1.65;color:#b9b9c0;margin:0;max-width:520px;text-wrap:pretty">
          Holowanie i transport aut osobowych oraz dostawczych — Myślenice i okolice. Jeden telefon i ruszamy, także
          poza standardowymi godzinami.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap">
          <a href="tel:+48791072708"
            style="display:inline-flex;align-items:center;gap:10px;background:#C8102E;color:#fff;padding:16px 30px;border-radius:4px;font-weight:700;font-size:15.5px">Zadzwoń: 791 072 708</a>
        </div>
      </div>
      <div style="min-height:340px;border-radius:6px;overflow:hidden">
        <img src="https://images.pexels.com/photos/12982224/pexels-photo-12982224.jpeg?auto=compress&cs=tinysrgb&w=1200"
          alt="Holowanie i pomoc drogowa" style="width:100%;height:100%;object-fit:cover;display:block">
      </div>
    </div>
  </section>

  <section style="padding:80px 32px">
    <div style="max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:28px">
      <h2 style="font-family:'Archivo Expanded','Archivo',sans-serif;font-size:28px;font-weight:800;margin:0">Zakres pomocy drogowej</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px">
        <div style="display:flex;flex-direction:column;gap:8px">
          <span style="font-weight:800;color:#C8102E">Auta osobowe</span>
          <p style="margin:0;font-size:14.5px;line-height:1.6;color:#5a5a60">Holowanie po awarii, stłuczce lub przy problemach z rozruchem — na miejsce naprawy lub docelowy adres.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <span style="font-weight:800;color:#C8102E">Auta dostawcze</span>
          <p style="margin:0;font-size:14.5px;line-height:1.6;color:#5a5a60">Transport busów i pojazdów dostawczych lawetą przystosowaną do większych gabarytów.</p>
        </div>
      </div>
      <p style="margin:0;font-size:15px;line-height:1.65;color:#5a5a60">Obsługujemy Myślenice i okolicę — zadzwoń, podaj lokalizację, a od razu ruszamy.</p>
    </div>
  </section>
</Layout>
